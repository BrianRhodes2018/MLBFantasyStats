# ===========================================================================
# .env.example — Frontend Environment Variables Template
# ===========================================================================
#
# HOW TO USE THIS FILE:
#   1. Copy this file to create your own .env:
#        cp .env.example .env
#   2. Edit .env with your actual values
#   3. Vite reads .env automatically when running "npm run dev" or "npm run build"
#
# IMPORTANT: Never commit .env to git! It might contain secrets.
#   .env is already in .gitignore so git won't track it.
#   This .env.example file IS safe to commit — it only has placeholder values.
#
# VITE ENVIRONMENT VARIABLE RULES:
#   - Only variables starting with VITE_ are available in browser code
#   - They're accessed via: import.meta.env.VITE_API_URL
#   - They're injected at BUILD TIME (not runtime), so you need to rebuild
#     after changing them
#   - This prevents accidentally exposing server-side secrets to the browser
#
# ===========================================================================


# ---------------------------------------------------------------------------
# VITE_API_URL — Backend API Base URL
# ---------------------------------------------------------------------------
# This tells the React app where the FastAPI backend is running.
#
# LOCAL DEVELOPMENT:
#   Leave empty (or don't set it). When empty, the app uses relative URLs
#   like fetch("/players/"), and Vite's dev proxy (configured in vite.config.js)
#   forwards them to http://localhost:8000.
#
# PRODUCTION (Vercel):
#   Set to your Render backend URL so API calls go directly to it.
#   Example: https://mlb-stats-api.onrender.com
#
#   In Vercel: Project Settings → Environment Variables → Add:
#     Key:   VITE_API_URL
#     Value: https://mlb-stats-api.onrender.com
#
VITE_API_URL=
