# ===========================================================================
# .env.example — Backend Environment Variables Template
# ===========================================================================
#
# HOW TO USE THIS FILE:
#   1. Copy this file to create your own .env:
#        cp .env.example .env
#   2. Edit .env with your actual values
#   3. The app reads .env automatically on startup (via python-dotenv)
#
# IMPORTANT: Never commit .env to git! It contains passwords and secrets.
#   .env is already in .gitignore so git won't track it.
#   This .env.example file IS safe to commit — it only has placeholder values.
#
# ===========================================================================


# ---------------------------------------------------------------------------
# DATABASE_URL — PostgreSQL Connection String
# ---------------------------------------------------------------------------
# This tells the app where your PostgreSQL database lives.
#
# FORMAT: postgresql+asyncpg://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# LOCAL DEVELOPMENT (default if not set):
#   Uses your local PostgreSQL server. Make sure PostgreSQL is running
#   and you've created a database called "mlb_db".
#
# PRODUCTION (Neon — free cloud PostgreSQL):
#   1. Sign up at https://neon.tech (free)
#   2. Create a project → copy the connection string
#   3. Paste it here (the app auto-converts the URL format and adds SSL)
#   Example: postgres://user:pass@ep-cool-name-123.us-east-2.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL=postgresql+asyncpg://postgres:admin123@localhost:5432/mlb_db


# ---------------------------------------------------------------------------
# CORS_ORIGINS — Allowed Frontend URLs (comma-separated)
# ---------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) controls which websites can call this API.
# Without this, browsers block requests from different domains for security.
#
# LOCAL DEVELOPMENT:
#   Leave empty — the app always allows http://localhost:5173 (Vite dev server).
#
# PRODUCTION:
#   Set to your deployed frontend URL so browsers allow it to call the API.
#   Example: https://your-app.vercel.app
#   Multiple origins: https://your-app.vercel.app,https://custom-domain.com
#
CORS_ORIGINS=
