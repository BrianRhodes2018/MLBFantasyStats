# ===========================================================================
# Git Ignore - Files and folders that should NOT be committed to version control
# ===========================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
venv/
.venv/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Logs ---
logs/
*.log

# --- Node.js / React ---
node_modules/
dist/
dist-ssr/

# --- IDE ---
.vscode/
.idea/

# --- OS ---
.DS_Store
Thumbs.db

# --- Database ---
*.db
*.sqlite
*.sqlite3

# --- Local assistant/session data ---
.claude/

# --- Backtest / model-training artifacts (large, regenerable) ---
backend/.backtest_cache/
backend/backtest_results/
backend/data/
