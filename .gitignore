# ===========================================================================
# Git Ignore - Files and folders that should NOT be committed to version control
# ===========================================================================
# These are either auto-generated, contain secrets, or are too large for git.

# --- Python ---
__pycache__/          # Compiled Python bytecode (auto-generated)
*.py[cod]             # .pyc, .pyo, .pyd compiled files
*.egg-info/           # Package metadata
venv/                 # Virtual environment folder
.env                  # Environment variables (contains secrets like DB passwords!)

# --- Node.js / React ---
node_modules/         # npm packages (thousands of files, reinstalled from package.json)
dist/                 # Built frontend files (generated by `npm run build`)

# --- IDE ---
.vscode/              # VS Code settings
.idea/                # JetBrains IDE settings

# --- OS ---
.DS_Store             # macOS folder metadata
Thumbs.db             # Windows thumbnail cache

# --- Database ---
*.db                  # SQLite database files (local data, not for version control)

# --- Claude ---
.claude/              # Claude Code session data
